{
    email ADMIN_EMAIL_HERE
}

# 업데이트 클라이언트는 Basic Auth 자격 증명을 저장하지 않는다. 호텔의 고정 공인 IP
# 또는 호텔-VPS 간 VPN 대역만 허용한다. 실제 CIDR로 바꾸기 전에는 배포하지 않는다.
(hotel_only) {
    @outside_hotel not remote_ip ALLOWED_CIDRS_HERE
    respond @outside_hotel "Forbidden" 403
}

REMOTEPLUS_DOMAIN_HERE {
    import hotel_only
    encode zstd gzip
    root * /srv/remoteplus/site
    file_server

    header {
        X-Content-Type-Options nosniff
        Referrer-Policy no-referrer
        X-Frame-Options DENY
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        Permissions-Policy "camera=(), microphone=(), geolocation=()"
        Content-Security-Policy "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; object-src 'none'; base-uri 'none'; frame-ancestors 'none'"
    }
}

DOWNLOAD_DOMAIN_HERE {
    import hotel_only
    encode zstd gzip
    root * /srv/remoteplus
    file_server

    @manifest path /channels/*/manifest.json
    header @manifest Cache-Control "no-store"

    @versioned path /releases/*
    header @versioned Cache-Control "private, max-age=31536000, immutable"

    header {
        X-Content-Type-Options nosniff
        Referrer-Policy no-referrer
        X-Frame-Options DENY
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        Permissions-Policy "camera=(), microphone=(), geolocation=()"
    }
}
